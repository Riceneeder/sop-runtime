{"$schema":"../schemas/sop-definition.schema.json","defaults":{"workspace":"/tmp/sop-runtime-basic"},"description":"A minimal SOP definition accepted by the current validator.","entry_step":"collect_context","final_output":{"next_action":"${steps.collect_context.output.next_action}","summary":"${steps.collect_context.output.summary}","ticket_id":"${run.input.ticket_id}"},"input_schema":{"additionalProperties":false,"properties":{"ticket_id":{"minLength":1,"type":"string"},"workspace":{"minLength":1,"type":"string"}},"required":["ticket_id","workspace"],"type":"object"},"metadata":{"example":true},"name":"Basic SOP","policies":{"concurrency":{"key_template":"basic:${run.input.ticket_id}","mode":"singleflight"},"cooldown_secs":0,"idempotency_key_template":"basic:${run.input.ticket_id}","max_run_secs":300},"sop_id":"basic_sop","steps":[{"description":"Collect the context needed to handle one ticket.","executor":{"allow_network":false,"config":{"command_template":"collect-context --ticket ${ticket_id} --workspace ${workspace}"},"env":{},"kind":"tool","name":"collect_context","resource_limits":{"max_artifacts":2,"max_output_bytes":4096},"timeout_secs":120},"id":"collect_context","inputs":{"ticket_id":"${run.input.ticket_id}","workspace":"${run.input.workspace}"},"output_schema":{"additionalProperties":false,"properties":{"next_action":{"minLength":1,"type":"string"},"summary":{"minLength":1,"type":"string"}},"required":["summary","next_action"],"type":"object"},"retry_policy":{"backoff_secs":[5],"max_attempts":2,"retry_on":["tool_error","timeout"]},"supervision":{"allowed_outcomes":[{"description":"Accept the collected context and finish the run.","id":"complete"}],"default_outcome":"complete","owner":"main_agent"},"title":"Collect Context","transitions":{"complete":{"terminate":{"reason":"context_collected","run_status":"succeeded"}}}}],"version":"1.0.0"}