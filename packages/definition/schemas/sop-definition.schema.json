{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sop-definition.schema.json",
  "title": "SOP Definition",
  "description": "Structural JSON Schema for SOP definitions accepted by sop-runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sop_id",
    "name",
    "version",
    "entry_step",
    "input_schema",
    "policies",
    "steps",
    "final_output"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sop_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "entry_step": {
      "$ref": "#/$defs/step_id"
    },
    "input_schema": {
      "$ref": "#/$defs/object"
    },
    "defaults": {
      "$ref": "#/$defs/object"
    },
    "policies": {
      "$ref": "#/$defs/policies"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "final_output": {
      "allOf": [
        {
          "$ref": "#/$defs/object"
        },
        {
          "minProperties": 1
        }
      ]
    },
    "metadata": {
      "$ref": "#/$defs/object"
    }
  },
  "$defs": {
    "object": {
      "type": "object"
    },
    "step_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "outcome_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cooldown_secs",
        "max_run_secs",
        "idempotency_key_template",
        "concurrency"
      ],
      "properties": {
        "cooldown_secs": {
          "type": "integer",
          "minimum": 0
        },
        "max_run_secs": {
          "type": "integer",
          "minimum": 1
        },
        "idempotency_key_template": {
          "type": "string",
          "minLength": 1
        },
        "concurrency": {
          "$ref": "#/$defs/concurrency"
        }
      }
    },
    "concurrency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "key_template"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "allow_parallel",
            "drop_if_running",
            "singleflight"
          ]
        },
        "key_template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "inputs",
        "executor",
        "output_schema",
        "retry_policy",
        "supervision",
        "transitions"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/step_id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "inputs": {
          "$ref": "#/$defs/object"
        },
        "executor": {
          "$ref": "#/$defs/executor"
        },
        "output_schema": {
          "$ref": "#/$defs/object"
        },
        "retry_policy": {
          "$ref": "#/$defs/retry_policy"
        },
        "supervision": {
          "$ref": "#/$defs/supervision"
        },
        "transitions": {
          "$ref": "#/$defs/transitions"
        },
        "metadata": {
          "$ref": "#/$defs/object"
        }
      }
    },
    "executor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name",
        "timeout_secs",
        "allow_network",
        "env",
        "resource_limits"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "config": {
          "type": "object"
        },
        "timeout_secs": {
          "type": "integer",
          "minimum": 1
        },
        "allow_network": {
          "type": "boolean"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "resource_limits": {
          "$ref": "#/$defs/resource_limits"
        }
      }
    },
    "resource_limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_output_bytes",
        "max_artifacts"
      ],
      "properties": {
        "max_output_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "max_artifacts": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_attempts",
        "backoff_secs",
        "retry_on"
      ],
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "backoff_secs": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "retry_on": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "timeout",
              "tool_error",
              "invalid_output",
              "sandbox_error"
            ]
          }
        }
      }
    },
    "supervision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "allowed_outcomes",
        "default_outcome"
      ],
      "properties": {
        "owner": {
          "const": "main_agent"
        },
        "allowed_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/allowed_outcome"
          }
        },
        "default_outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "allowed_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/outcome_id"
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transitions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/transition"
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "next_step": {
          "$ref": "#/$defs/step_id"
        },
        "terminate": {
          "$ref": "#/$defs/terminal_state"
        }
      },
      "oneOf": [
        {
          "required": [
            "next_step"
          ],
          "not": {
            "required": [
              "terminate"
            ]
          }
        },
        {
          "required": [
            "terminate"
          ],
          "not": {
            "required": [
              "next_step"
            ]
          }
        }
      ]
    },
    "terminal_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_status",
        "reason"
      ],
      "properties": {
        "run_status": {
          "type": "string",
          "enum": [
            "succeeded",
            "failed",
            "cancelled"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
