{
  "name": "@sop-runtime/definition",
  "version": "0.3.0-alpha.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema/sop-definition.schema.json": "./schemas/sop-definition.schema.json",
    "./examples/basic_sop_definition.json": "./examples/basic_sop_definition.json"
  },
  "files": [
